{
  "name": "agent-registry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "tsc -b --pretty false",
    "test": "bash tests/workspace-foundation.test.sh --mode=outer",
    "test:inner": "bash tests/workspace-foundation.test.sh --mode=inner",
    "migrate": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/migrate.ts",
    "seed": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "yaml": "^2.8.1"
  }
}
