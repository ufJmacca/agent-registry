{
  "name": "agent-registry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "tsc -b --pretty false",
    "test": "bash tests/workspace-foundation.test.sh --mode=outer && npm run test:unit",
    "test:inner": "bash tests/workspace-foundation.test.sh --mode=inner && npm run test:unit",
    "test:unit": "tsx --test tests/*.test.ts",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "yaml": "^2.8.1"
  }
}
